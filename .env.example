# Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model used for message analysis.
OPENAI_MODEL=gpt-5.5

# Optional GitHub-editable monitoring config.
# If set, the bot reloads channel/user/keyword routing from this URL.
MONITORING_CONFIG_URL=
MONITORING_CONFIG_REFRESH_SECONDS=300

# Channel-specific rules. Use semicolons between channels and pipes between terms.
# Format: channel_id:term|term|term;channel_id:term|term
# When set, this overrides MONITORED_CHANNEL_IDS and WATCH_TERMS.
CHANNEL_RULES=

# Channel-specific users to tag. Use semicolons between channels and pipes between users.
# Format: channel_id:user_id|user_id;channel_id:user_id
# When set for a channel, this overrides MENTION_USER_ID and MENTION_USER_IDS for that channel.
CHANNEL_MENTION_USER_IDS=

# Comma-separated Discord channel IDs to monitor.
# Leave empty to monitor every text channel the bot can see.
MONITORED_CHANNEL_IDS=

# Comma-separated words or phrases that trigger analysis.
# Leave empty to analyze every message in monitored channels.
WATCH_TERMS=urgent,refund,chargeback,security

# Actions to run when OpenAI says a message needs attention.
# Valid values: mention, forward
ALERT_ACTIONS=mention,forward

# User ID to mention in the source channel when ALERT_ACTIONS includes "mention".
MENTION_USER_ID=

# Comma-separated user IDs to mention globally when ALERT_ACTIONS includes "mention".
MENTION_USER_IDS=

# Destination channel ID when ALERT_ACTIONS includes "forward".
FORWARD_CHANNEL_ID=

# Also mention the configured user ID(s) in the forwarded alert.
MENTION_IN_FORWARD=false
